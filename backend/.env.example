# ── LLM: Paytm Inference (OpenAI-compatible base URL) ──
# Base URL must be reachable from this machine (DNS/VPN). Include /v1 if your gateway expects it.
# Wrong host → Windows: getaddrinfo failed / Connection error from LiteLLM.
PAYTM_API_KEY=your_paytm_api_key
PAYTM_BASE_URL=https://api.inference.paytm.com/v1
# If URLs like https://api.host (no path) gave HTML “Access Denied”, we append /v1 automatically.
# Set only if your gateway deliberately has no /v1 suffix:
# PAYTM_SKIP_BASE_URL_NORMALIZE=1
# PAYTM_HTTP_USER_AGENT=...
# PAYTM_EXTRA_HEADERS_JSON={"Some-Header":"value-from-paytm-docs"}

# Optional — per-agent OpenAI-style model ids provisioned on your account (403 if unassigned)
# PAYTM_MODEL_PLANNER=openai/qwen/qwen3-32b
# PAYTM_MODEL_RESEARCHER=openai/llama-3.3-70b-versatile
# PAYTM_MODEL_ANALYST=openai/moonshotai.kimi-k2-thinking
# PAYTM_MODEL_WRITER=openai/llama-3.3-70b-versatile
# PAYTM_MODEL_EDITOR=openai/llama-3.3-70b-versatile

# ── Web Search ─────────────────────────────────────────
SERPER_API_KEY=your_serper_api_key

# ── Supabase ───────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
# Must be your **secret** API key (`sb_secret_…` — new projects) OR the legacy
# **service_role** JWT shown under “Project API keys”. Do NOT use `sb_publishable_…` here.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Optional — only if you do NOT use remote verify above:
# Must match Supabase Dashboard → Settings → API → JWT Secret (not a random string).
# JWT_SECRET=

# ── App Config ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173
MAX_CONCURRENT_JOBS=3
